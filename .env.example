# Copy to .env and adjust. All values are optional — the defaults target a
# local mc-manager-server on port 8080. Vite inlines these at build time,
# so rebuild (or restart `npm run dev`) after changing them.

# Base URL of the mc-manager REST API.
VITE_API_BASE=http://localhost:8080/api

# WebSocket URL of the live console.
VITE_WS_URL=ws://localhost:8080/api/console

# Optional: default URL for the player panel's "View on live map" link.
# Leave unset to hide it; it can also be set at runtime on the Settings page.
# VITE_BLUEMAP_URL=https://map.example.com
