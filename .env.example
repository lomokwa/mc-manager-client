# Copy to .env and adjust. Vite only exposes variables prefixed with VITE_.

# --- Recommended for local development: proxy through the dev server ---
# Set VITE_API_PROXY to your server's origin and `npm run dev` forwards /api
# (and the console WebSocket) to it. The browser only ever talks to localhost,
# so you avoid CORS entirely and don't need the server to allow your origin.
VITE_API_PROXY=https://mine.lomokwa.com
VITE_API_BASE=/api
VITE_WS_URL=/api/console

# --- Alternative: call the API directly (no proxy) ---
# Leave VITE_API_PROXY unset and point these at the server. The server must
# then send CORS headers that allow this origin (see the server's
# CORS_ALLOWED_ORIGINS setting).
# VITE_API_BASE=https://mine.lomokwa.com/api
# VITE_WS_URL=wss://mine.lomokwa.com/api/console

# API key — must match the server's API_KEY. Sent as the X-API-Key header
# (and ?key= on the WebSocket).
# NOTE: this is bundled into the built client and is readable by anyone with
# the page. Don't ship a privileged key to an untrusted audience.
VITE_API_KEY=changeme
